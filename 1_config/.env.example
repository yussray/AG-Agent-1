# ============================================================
# .env.example — Antigravity Multi-Agent System
# Copy this file to .env and fill in your real values
# cp .env.example .env
# ============================================================

# -- AnythingLLM -----------------------------------------
# Get from: AnythingLLM -> Settings -> API Keys
ANYTHINGLLM_API_KEY=your-anythingllm-api-key-here

# -- Telegram Bot ----------------------------------------
# Get from: @BotFather on Telegram -> /newbot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# -- Tavily Search ---------------------------------------
# Get from: https://app.tavily.com -> API Keys
TAVILY_API_KEY=your-tavily-api-key-here

# -- Host Overrides (Docker auto-sets these) -------------
# OLLAMA_HOST=http://host.docker.internal:11434
# ANYTHINGLLM_HOST=http://host.docker.internal:3001

# -- Model Overrides (optional) --------------------------
# ROUTER_MODEL=qwen2.5:7b
# REASONING_MODEL=qwen2.5:7b
# CODER_MODEL=qwen2.5-coder:7b
# VISION_MODEL=dcarrascosa/medgemma-1.5-4b-it:Q8_0

# -- Whisper (speech-to-text) ----------------------------
# Options: tiny | base | small | medium | large
WHISPER_MODEL=base
